<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="YouTube Screen Recorder"
           Manufacturer="Soft Standard"
           Version="$(var.Version)"
           UpgradeCode="E7A3C1F2-4B5D-4E8A-9C0F-1D2E3F4A5B6C"
           Scope="perMachine"
           Compressed="true">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />

    <!-- ================================================================
         Directory tree
         ================================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="YouTubeScreenRecorder" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="YouTube Screen Recorder" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ================================================================
         Shortcut components
         ================================================================ -->
    <ComponentGroup Id="StartMenuShortcut" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcutComp" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <Shortcut Id="StartMenuSC"
                  Name="YouTube Screen Recorder"
                  Description="Record your screen in high quality"
                  Target="[INSTALLDIR]YouTubeScreenRecorder.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\SoftStandard\YouTubeScreenRecorder"
                       Name="StartMenuShortcut"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DesktopShortcut" Directory="DesktopFolder">
      <Component Id="DesktopShortcutComp" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <Shortcut Id="DesktopSC"
                  Name="YouTube Screen Recorder"
                  Description="Record your screen in high quality"
                  Target="[INSTALLDIR]YouTubeScreenRecorder.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RegistryValue Root="HKCU"
                       Key="Software\SoftStandard\YouTubeScreenRecorder"
                       Name="DesktopShortcut"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Features — AppFiles component group is generated by build-installer.ps1
         ================================================================ -->
    <Feature Id="ProductFeature" Title="YouTube Screen Recorder" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature"
             Title="Desktop shortcut"
             Description="Add a shortcut to the desktop"
             Level="1">
      <ComponentGroupRef Id="DesktopShortcut" />
    </Feature>

  </Package>
</Wix>
