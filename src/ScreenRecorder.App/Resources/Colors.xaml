<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FF131620" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF1B1F2A" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF232838" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FF333B4D" />

    <SolidColorBrush x:Key="AccentBrush" Color="#FFE53935" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFF0564B" />
    <SolidColorBrush x:Key="InfoBrush" Color="#FF4EA1F2" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF2F4F8" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFAEB6C6" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF707A8C" />

</ResourceDictionary>
